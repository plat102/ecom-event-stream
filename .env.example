# ── Kafka source (external) ──────────────────────────────────────────
SOURCE_KAFKA_BROKERS=
SOURCE_KAFKA_TOPIC=
SOURCE_KAFKA_GROUP_ID=
SOURCE_KAFKA_SECURITY_PROTOCOL=
SOURCE_KAFKA_SASL_MECHANISM=
SOURCE_KAFKA_SASL_USERNAME=
SOURCE_KAFKA_SASL_PASSWORD=

# ── Kafka self-hosted (from docker-compose) ─────────────────────────
LOCAL_KAFKA_BROKERS=localhost:9092
LOCAL_KAFKA_TOPIC=user-events
LOCAL_KAFKA_DLQ_TOPIC=user-events-dlq

# ── MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=ecom_events

# ── Logging ──────────────────────────────────────────────────────────
LOG_FORMAT=pretty
