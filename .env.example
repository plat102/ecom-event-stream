# ── Kafka source (external) ──────────────────────────────────────────
SOURCE_KAFKA_BROKERS=
SOURCE_KAFKA_TOPIC=
SOURCE_KAFKA_GROUP_ID=
SOURCE_KAFKA_SECURITY_PROTOCOL=SASL_PLAINTEXT
SOURCE_KAFKA_SASL_MECHANISM=PLAIN
SOURCE_KAFKA_SASL_USERNAME=
SOURCE_KAFKA_SASL_PASSWORD=

# ── Kafka self-hosted (from docker-compose) ─────────────────────────
SINK_KAFKA_BROKERS=localhost:9094
SINK_KAFKA_TOPIC=user-events
SINK_KAFKA_DLQ_TOPIC=user-events-dlq
SINK_KAFKA_SECURITY_PROTOCOL=SASL_PLAINTEXT
SINK_KAFKA_SASL_MECHANISM=PLAIN
SINK_KAFKA_SASL_USERNAME=kafka
SINK_KAFKA_SASL_PASSWORD=

# ── MongoDB
MONGO_URI=mongodb://admin:Mongo@2026@localhost:27017
MONGO_DB=ecom_events

# ── Logging ──────────────────────────────────────────────────────────
LOG_FORMAT=pretty
